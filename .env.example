# Copy to .env and adjust. docker-compose reads this file automatically.

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=gapido_auth

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# --- OTP policy ---
OTP_TTL_SECONDS=120
OTP_LENGTH=6
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_REQUESTS_PER_HOUR=5
# Server-side pepper for OTP hashing. Generate like JWT_SECRET.
OTP_PEPPER=change-me-too

# --- SMS provider ---
# "console" logs the OTP instead of sending (no API key needed).
# "kavenegar" sends real SMS via Kavenegar Verify Lookup.
SMS_PROVIDER=console
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=

# --- Roles ---
# Comma-separated phone numbers that get the admin role on first login.
ADMIN_PHONES=09120000000

# --- Server ---
GRPC_PORT=50051

# --- Host port mappings (docker-compose only) ---
# Change these if another RabbitMQ already publishes the default ports.
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
